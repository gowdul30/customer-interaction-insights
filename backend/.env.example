# Gemini API Key (Obtain from Google AI Studio)
GEMINI_API_KEY=your-gemini-api-key-here

# LangSmith Observability Configuration (Optional)
# 1. Sign up at https://smith.langchain.com (Free tier: 5,000 traces/month)
# 2. Create a project named "customer-interaction-insights"
# 3. Generate an API Key and paste it below
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=customer-interaction-insights
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
